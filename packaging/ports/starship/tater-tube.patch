@@ -322,7 +322,9 @@ void aADPCMdecImpl(uint8_t flags, ADPCM_STATE state) {
 
             __m128i ins_vec;
             if (flags & 4) {
-                ins_vec = _mm_loadu_si16((__m128i*) in);
+                uint16_t packed_ins;
+                memcpy(&packed_ins, in, sizeof(packed_ins));
