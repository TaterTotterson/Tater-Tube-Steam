{
  "id": "com.240mp.usenet",
  "name": "The Tube",
  "order": 5,
  "icon": "assets/images/logo.svg",
  "entry_point_qml": "views/Root.qml",
  "settings": [
    {
      "key": "enabled",
      "label": "ENABLED",
      "type": "toggle",
      "default": "ON"
    },
    {
      "key": "tater_server_url",
      "label": "TATER SERVER URL",
      "type": "text",
      "default": ""
    },
    {
      "key": "tater_server_token",
      "label": "TATER PLAYER TOKEN",
      "type": "text",
      "default": ""
    },
    {
      "key": "tater_picks_narration",
      "label": "TATER PICKS NARRATION",
      "type": "toggle",
      "default": "ON"
    },
    {
      "key": "tube_transcode_mode",
      "label": "TRANSCODING",
      "type": "list_single",
      "options": ["On", "Off"],
      "default": "On"
    },
    {
      "key": "tube_transcode_quality",
      "label": "TRANSCODE QUALITY",
      "type": "list_single",
      "options": ["Auto", "CRT 480p", "HDMI 720p", "HDMI 1080p", "HDMI 4K"],
      "default": "Auto"
    },
    {
      "key": "browse_limit",
      "label": "BROWSE LIMIT",
      "type": "list_single",
      "options": ["50", "100", "250", "500"],
      "default": "100"
    },
    {
      "key": "stream_timeout",
      "label": "STREAM TIMEOUT",
      "type": "list_single",
      "options": ["120", "300", "600", "900"],
      "default": "300"
    }
  ]
}
