#!/usr/bin/env bash
set -euo pipefail

DEFAULT_MANIFEST_URL="https://raw.githubusercontent.com/TaterTotterson/240-MP-Emby-Jelly/main/update-manifest.json"
MANIFEST_URL="${1:-${MP240_UPDATE_MANIFEST_URL:-$DEFAULT_MANIFEST_URL}}"
INSTALL_PREFIX="${MP240_INSTALL_PREFIX:-/opt/240mp}"
SERVICE_NAME="${MP240_SERVICE_NAME:-240mp.service}"
UPDATE_FLAG="${MP240_UPDATE_FLAG:-/run/240mp-updating}"
TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/240mp-update.XXXXXX")"
SERVICE_STOPPED=0

cleanup() {
    local status=$?
    rm -rf "$TMP_DIR"
    rm -f "$UPDATE_FLAG"

    if [ "$SERVICE_STOPPED" = "1" ] && [ "$status" -ne 0 ]; then
        systemctl start "$SERVICE_NAME" >/dev/null 2>&1 || true
    fi
}
trap cleanup EXIT

log() {
    printf '[240mp-update] %s\n' "$*"
}

require_root() {
    if [ "$(id -u)" -ne 0 ]; then
        log "This updater must run as root."
        exit 1
    fi
}

require_cmd() {
    if ! command -v "$1" >/dev/null 2>&1; then
        log "Missing required command: $1"
        exit 1
    fi
}

require_root
require_cmd curl
require_cmd python3
require_cmd tar
require_cmd systemctl

log "Fetching manifest: $MANIFEST_URL"
curl -fsSL "$MANIFEST_URL" -o "$TMP_DIR/manifest.json"

mapfile -t manifest_values < <(python3 - "$TMP_DIR/manifest.json" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    manifest = json.load(handle)

repo = manifest.get("repo", "").rstrip("/")
binary_archive = manifest.get("binary_archive", "")

print(manifest.get("version", ""))
print(binary_archive)
print(repo)
PY
)

VERSION="${manifest_values[0]:-}"
BINARY_ARCHIVE="${manifest_values[1]:-}"
REPO_URL="${manifest_values[2]:-}"

if [ -z "$VERSION" ] || [ -z "$BINARY_ARCHIVE" ]; then
    log "Manifest is missing version or binary_archive."
    exit 1
fi

log "Preparing version $VERSION from ${REPO_URL:-prebuilt archive}"
curl -fsSL "$BINARY_ARCHIVE" -o "$TMP_DIR/update.tar.gz"

mkdir -p "$TMP_DIR/install"
tar -xzf "$TMP_DIR/update.tar.gz" -C "$TMP_DIR/install" --strip-components=3

SETUP_HELPER="$TMP_DIR/install/share/240mp/scripts/lib/pi-setup.sh"
if [ ! -f "$SETUP_HELPER" ]; then
    log "Downloaded archive is missing Raspberry Pi service setup helper: $SETUP_HELPER"
    exit 1
fi

# shellcheck source=/dev/null
source "$SETUP_HELPER"

log "Installing missing runtime dependencies"
if ! pi240_install_missing_runtime_dependencies; then
    log "Warning: could not install every missing runtime package; continuing with app update."
fi

log "Installing update"
touch "$UPDATE_FLAG"
SERVICE_STOPPED=1
systemctl stop "$SERVICE_NAME" || true

install -d -m 0755 "$INSTALL_PREFIX"
cp -a "$TMP_DIR/install/." "$INSTALL_PREFIX/"
install -d -m 0755 "$INSTALL_PREFIX/share/240mp"
install -m 0644 "$TMP_DIR/manifest.json" "$INSTALL_PREFIX/share/240mp/update-manifest.json"

SETUP_HELPER="$INSTALL_PREFIX/share/240mp/scripts/lib/pi-setup.sh"
if [ ! -f "$SETUP_HELPER" ]; then
    log "Installed archive is missing Raspberry Pi service setup helper: $SETUP_HELPER"
    exit 1
fi

log "Refreshing Raspberry Pi service setup"

SERVICE_USER="$(systemctl show "$SERVICE_NAME" -p User --value 2>/dev/null || true)"
SERVICE_USER="${SERVICE_USER:-mp240}"
SERVICE_HOME="$(getent passwd "$SERVICE_USER" 2>/dev/null | cut -d: -f6 || true)"
SERVICE_HOME="${SERVICE_HOME:-/var/lib/240mp}"

pi240_create_service_user "$SERVICE_USER" "$SERVICE_HOME"
pi240_install_tty_rule
pi240_install_launcher "$INSTALL_PREFIX" /usr/local/bin/240mp
pi240_install_autostart "$SERVICE_USER" /usr/local/bin/240mp "/etc/systemd/system/${SERVICE_NAME}" "$SERVICE_HOME"
pi240_install_update_helper "$SERVICE_USER" /usr/local/sbin/240mp-update "$INSTALL_PREFIX/share/240mp/scripts/240mp-update"
pi240_install_ssh_control "$SERVICE_USER" /usr/local/sbin/240mp-ssh-control
pi240_auto_force_composite_video
if [ "${MP240_ENABLE_IR:-1}" = "1" ]; then
    pi240_install_ir_support "${MP240_IR_PROTOCOL:-nec}" /etc/rc_keymaps/240mp.toml "${MP240_IR_GPIO_PIN:-17}"
    pi240_enable_ir_overlay "${MP240_IR_GPIO_PIN:-17}"
fi
if [ "${MP240_ENABLE_BOOT_SPLASH:-1}" = "1" ]; then
    pi240_install_boot_splash
fi

systemctl daemon-reload || true
systemctl start "$SERVICE_NAME"
SERVICE_STOPPED=0
rm -f "$UPDATE_FLAG"

log "Updated 240-MP to $VERSION"
